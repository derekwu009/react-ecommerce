datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
}

model User {
  user_id       BigInt @id @default(autoincrement())
  user_name     String 
  user_email    String
  user_password String
  cartItems     Cart[] @relation("UserCart")
}

model Cart {
  user_id  BigInt
  book_id  Int
  quantity Int    @default(1)
  user     User   @relation(fields: [user_id], references: [user_id], name:"UserCart")

  @@id([user_id, book_id])
}
